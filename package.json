{
  "name": "48-starter-flask",
  "private": false,
  "version": "2.1.0",
  "description": "Lightweight Flask/React starter modernized with React 19, Vite 6, and Tailwind CSS v4. Academic/Research theme.",
  "type": "module",
  "scripts": {
    "production": "npm run build && npm start",
    "lint": "eslint .",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "clean": "rm -rf node_modules coverage dist build",
    "fresh": "npm run clean && npm install"
  },
  "keywords": [
    "flask",
    "react",
    "starter",
    "tailwind",
    "typescript",
    "python"
  ],
  "author": "Kazi Musharraf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mk-knight23/48-starter-flask.git"
  },
  "homepage": "https://mk-knight23.github.io/48-starter-flask/",
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.23",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}